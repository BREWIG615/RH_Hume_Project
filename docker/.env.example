# =============================================================================
# RH Hume Project - Environment Variables
# =============================================================================
# Copy this file to .env and fill in your values:
#   cp .env.example .env
#
# NEVER commit .env to version control!
# =============================================================================

# -----------------------------------------------------------------------------
# Neo4j Configuration
# -----------------------------------------------------------------------------
NEO4J_PASSWORD=your_secure_password_here

# -----------------------------------------------------------------------------
# API Keys (Required)
# -----------------------------------------------------------------------------

# Anthropic Claude API
# Get from: https://console.anthropic.com
CLAUDE_API_KEY=sk-ant-api03-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Hume AI API
# Get from: https://platform.hume.ai
HUME_API_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# OpenAI API (for embeddings)
# Get from: https://platform.openai.com
# Note: Can be skipped if using local embeddings (BGE)
OPENAI_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# -----------------------------------------------------------------------------
# Application Configuration
# -----------------------------------------------------------------------------

# Environment: development, staging, production
APP_ENVIRONMENT=development

# Logging level: DEBUG, INFO, WARNING, ERROR
LOG_LEVEL=INFO

# -----------------------------------------------------------------------------
# Feature Flags
# -----------------------------------------------------------------------------
FEATURE_KAFKA_ENABLED=true
FEATURE_RELATIONSHIP_VERSIONING=true
FEATURE_SOURCE_REPUTATION_LEARNING=true
FEATURE_SCENARIO_BRANCHING=false

# -----------------------------------------------------------------------------
# Kafka Configuration (usually no changes needed)
# -----------------------------------------------------------------------------
KAFKA_BOOTSTRAP_SERVERS=kafka:29092

# -----------------------------------------------------------------------------
# Optional: Secrets Provider (production)
# -----------------------------------------------------------------------------
# SECRETS_PROVIDER=environment  # environment, aws, vault
# AWS_REGION=us-east-1
# VAULT_URL=https://vault.example.com
# VAULT_TOKEN=hvs.xxxxxxxxxxxxx
